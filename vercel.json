{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["bom1"],
  "functions": {
    "api/todays-cause-list.py": { "maxDuration": 60 },
    "api/match-todays-listings.py": { "maxDuration": 60 },
    "api/debug/match-case.py": { "maxDuration": 30 },
    "api/mhc/case-status.py": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
